# Eiden AI CRM — Environment Variables

# ─── REQUIRED ───────────────────────────────────────────────────────────────────
# Claude AI (Anthropic) — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── OPTIONAL ───────────────────────────────────────────────────────────────────
# Slack integration (for /api/integrations/slack/message)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# IBMS v1 auth/webhook hardening
AUTH_TOKEN_SECRET=your_auth_token_secret_here
AUTH_TOKEN_TTL_SECONDS=43200
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Server port (default: 3000)
# PORT=3000

# ─── FIREBASE CLOUD MESSAGING (Server-side only) ─────────────────────────────
# Get these from Firebase Console → Project Settings → General → Your Apps
# These are used by the backend to provide config to the frontend
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
FIREBASE_VAPID_KEY=your_vapid_key

# Firebase Service Account (from Firebase Console → Project Settings → Service Accounts)
# Replace newlines with \n when adding to .env
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
